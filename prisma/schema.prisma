generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id                 String    @id @default(cuid())
  name               String
  optedIn            Boolean   @default(false)
  lastContributionAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users            User[]
  patients         Patient[]
  episodes         Episode[]
  clinicalUpdates  ClinicalUpdate[]
  simulationEvents SimulationEvent[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("clinician")
  clinicId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic           Clinic            @relation(fields: [clinicId], references: [id])
  episodes         Episode[]
  clinicalUpdates  ClinicalUpdate[]
  simulationEvents SimulationEvent[]
}

model Patient {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  clinicId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic   Clinic    @relation(fields: [clinicId], references: [id])
  episodes Episode[]
}

model Episode {
  id        String   @id @default(cuid())
  patientId String
  clinicId  String
  userId    String
  reason    String
  startDate DateTime
  createdAt DateTime @default(now())

  patient         Patient          @relation(fields: [patientId], references: [id])
  clinic          Clinic           @relation(fields: [clinicId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  clinicalUpdates ClinicalUpdate[]
}

model ClinicalUpdate {
  id                  String   @id @default(cuid())
  episodeId           String
  clinicId            String
  userId              String
  painRegion          String
  diagnosis           String
  treatmentModalities String
  redFlags            Boolean  @default(false)
  notes               String   @default("")
  createdAt           DateTime @default(now())

  episode Episode @relation(fields: [episodeId], references: [id])
  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model SimulationEvent {
  id        String   @id @default(cuid())
  type      String
  clinicId  String
  userId    String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}
